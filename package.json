{
  "name": "job-hunter-ai",
  "version": "1.0.0",
  "description": "AI-powered job search and resume tailoring desktop app",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev": "npm start",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "backend": "cd backend && python3 main.py",
    "setup": "npm install && pip3 install -r backend/requirements.txt --break-system-packages"
  },
  "build": {
    "appId": "com.jobhunter.ai",
    "productName": "JobHunter AI",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**", "electron/**", "backend/**"],
    "mac": { "category": "public.app-category.productivity" }
  },
  "dependencies": {
    "axios": "^1.6.7",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.6",
    "wait-on": "^7.2.0"
  }
}
